# Flight data provider — server-only, never exposed to the client.
# Leave these unset to keep `/api/flights/search` returning 503
# ("Flight data service is not configured."). The Add Flight screen
# shows honest "Live flight search is not connected yet." copy in
# that case.
#
# Currently supported value: `aviationstack`.
# Add more by implementing FlightProviderAdapter in
# src/lib/flights/providers/ and wiring it in providers/index.ts.
FLIGHT_DATA_PROVIDER=
FLIGHT_DATA_API_KEY=

# Auth.js (NextAuth v5) — server-only, never exposed to the client.
# Leave these unset to keep the /onboarding/sign-in screen showing
# every provider row as "Soon" with "Continue as guest" as the
# active path.
#
# AUTH_SECRET   — required for any provider to work in production.
#                 Generate with: npx auth secret
# AUTH_URL      — public origin used for OAuth callbacks
#                 (e.g. http://localhost:3000 in dev).
AUTH_SECRET=
AUTH_URL=

# Google OAuth — set both to enable the "Continue with Google" row.
# Create credentials at https://console.cloud.google.com/apis/credentials
# with redirect URI {AUTH_URL}/api/auth/callback/google.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
